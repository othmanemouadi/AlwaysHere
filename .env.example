# --- Database ---
# Local dev: `docker compose up -d` starts Postgres on 5439 matching this URL.
DATABASE_URL=postgres://alwayshere:alwayshere@localhost:5439/alwayshere

# --- Sessions ---
# Any long random string. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# --- OpenAI (AI receptionist brain) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Twilio (voice + SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# The Twilio phone number callers are forwarded to (E.164), also used as SMS sender.
TWILIO_NUMBER=+15551234567

# --- Public URL of this app (required for Twilio webhooks + signature validation) ---
# Local dev: use an `ngrok http 3000` (or `cloudflared tunnel`) URL.
PUBLIC_BASE_URL=https://your-domain.example.com

# --- Google Calendar sync (optional; appointments stay in the DB if unset) ---
# Create a service account, enable the Calendar API, share the target calendar
# with the service account email, then set:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=bot@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CALENDAR_ID=primary-or-calendar-id@group.calendar.google.com
